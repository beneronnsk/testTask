@model List<TestTask.Models.StatusHistory>

<h2>История смены статусов: @ViewBag.PersonName</h2>
<table class="table mt-3">
    <thead>
        <tr>
            <th>Дата и время</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var h in Model)
        {
            <tr>
                @* Добавляем .ToLocalTime() здесь *@
                <td>@h.ChangeDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>

                <td><span class="badge bg-info text-dark">@h.StatusName</span></td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Назад</a>