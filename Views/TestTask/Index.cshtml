@model List<TestTask.Models.Person>

@{
    int pageSize = 15;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int startNumber = (currentPage - 1) * pageSize + 1;
    string sortBy = ViewBag.SortBy ?? "name";
    bool sortDesc = ViewBag.SortDesc ?? false;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Список клиентов</h2>
        <a asp-controller="TestTask" asp-action="AddPerson" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Добавить клиента
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px" class="ps-3">№</th>
                        <th>
                            <a asp-action="Index"
                                   asp-route-sortBy="name"
                                   asp-route-sortDesc="@(sortBy == "name" ? !sortDesc : false)"
                                   class="text-decoration-none text-dark fw-bold">
                                ФИО @(sortBy == "name" ? (sortDesc ? "↓" : "↑") : "")
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                                   asp-route-sortBy="birthday"
                                   asp-route-sortDesc="@(sortBy == "birthday" ? !sortDesc : false)"
                                   class="text-decoration-none text-dark fw-bold">
                                Дата рождения @(sortBy == "birthday" ? (sortDesc ? "↓" : "↑") : "")
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                                   asp-route-sortBy="status"
                                   asp-route-sortDesc="@(sortBy == "status" ? !sortDesc : false)"
                                   class="text-decoration-none text-dark fw-bold">
                                Статус @(sortBy == "status" ? (sortDesc ? "↓" : "↑") : "")
                            </a>
                        </th>
                        <th class="text-end pe-3">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            <tr>
                                <td class="align-middle ps-3 text-muted">
                                    @(startNumber + i)
                                </td>
                                <td class="align-middle">
                                    <a asp-action="PersonHistory" asp-route-id="@item.Id" class="text-decoration-none fw-bold">
                                        @item.Surname @item.Name @item.Patronymic
                                    </a>
                                </td>
                                <td class="align-middle">
                                    @item.Birthday.ToString("dd.MM.yyyy")
                                </td>
                                <td class="align-middle">
                                    @{
                                        var badgeClass = item.PersonStatusDict?.Status == "Активен" ? "bg-success" : "bg-secondary";
                                    }
                                    <span class="badge @badgeClass">
                                        @(item.PersonStatusDict?.Status ?? "Не указан")
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <a asp-controller="TestTask"
                                           asp-action="EditPagePerson"
                                           asp-route-idPerson="@item.Id"
                                           class="btn btn-outline-primary btn-sm">
                                        Редактировать
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Пользователи пока не добавлены
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-sortBy="@sortBy"
                           asp-route-sortDesc="@sortDesc">Назад</a>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-sortBy="@sortBy"
                           asp-route-sortDesc="@sortDesc">@i</a>
                    </li>
                }

                @if (currentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-sortBy="@sortBy"
                           asp-route-sortDesc="@sortDesc">Вперед</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>