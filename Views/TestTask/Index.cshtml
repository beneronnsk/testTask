@model List<TestTask.Models.Person>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Список клиентов</h2>
        <a asp-controller="TestTask" asp-action="AddPerson" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Добавить клиента
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ФИО</th>
                        <th>Дата рождения</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">
                                    <a asp-action="PersonHistory" asp-route-id="@item.Id" class="text-decoration-none fw-bold">
                                        @item.Surname @item.Name @item.Patronymic
                                    </a>
                                </td>
                                <td class="align-middle">
                                    @item.Birthday.ToString("dd.MM.yyyy")
                                </td>
                                <td class="align-middle">
                                    @{
                                        var badgeClass = item.PersonStatusDict?.Status == "Активный" ? "bg-success" : "bg-secondary";
                                    }
                                    <span class="badge @badgeClass">
                                        @(item.PersonStatusDict?.Status ?? "Не указан")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="TestTask"
                                       asp-action="EditPagePerson"
                                       asp-route-idPerson="@item.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        Редактировать
                                    </a>
                                </td>
                            </tr>
                                            
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                Пользователи пока не добавлены
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>